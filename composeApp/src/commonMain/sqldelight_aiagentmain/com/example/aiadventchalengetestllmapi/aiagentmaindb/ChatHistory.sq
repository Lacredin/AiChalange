CREATE TABLE chats (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    selected_profile_id INTEGER REFERENCES chat_profiles(id) ON DELETE SET NULL
);

CREATE TABLE chat_messages (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    api TEXT NOT NULL,
    model TEXT NOT NULL,
    role TEXT NOT NULL,
    message TEXT NOT NULL,
    params_info TEXT NOT NULL,
    created_at INTEGER NOT NULL
);

CREATE TABLE chat_profiles (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    is_long_term_memory_enabled INTEGER NOT NULL,
    is_system_prompt_enabled INTEGER NOT NULL,
    system_prompt_text TEXT NOT NULL,
    is_summarization_enabled INTEGER NOT NULL,
    summarize_after_tokens TEXT NOT NULL,
    is_sliding_window_enabled INTEGER NOT NULL,
    sliding_window_size TEXT NOT NULL,
    is_sticky_facts_enabled INTEGER NOT NULL,
    sticky_facts_window_size TEXT NOT NULL,
    sticky_facts_system_message TEXT NOT NULL,
    is_branching_enabled INTEGER NOT NULL,
    show_raw_history INTEGER NOT NULL
);

CREATE TABLE chat_branch_messages (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    branch_number INTEGER NOT NULL,
    role TEXT NOT NULL,
    message TEXT NOT NULL,
    params_info TEXT NOT NULL,
    stream TEXT NOT NULL,
    epoch INTEGER NOT NULL,
    created_at INTEGER NOT NULL
);

CREATE TABLE memory_entries (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    profile_id INTEGER NOT NULL REFERENCES chat_profiles(id) ON DELETE CASCADE,
    entry_key TEXT NOT NULL,
    entry_value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

selectChats:
SELECT *
FROM chats
ORDER BY id ASC;

insertChat:
INSERT INTO chats(
    title,
    created_at,
    selected_profile_id
)
VALUES (?, ?, ?);

selectChatById:
SELECT *
FROM chats
WHERE id = ?;

selectLastInsertedChatId:
SELECT last_insert_rowid();

selectMessagesByChat:
SELECT *
FROM chat_messages
WHERE chat_id = ?
ORDER BY id ASC;

selectFeatureStateByChat:
SELECT *
FROM chat_profiles
WHERE id = (
    SELECT selected_profile_id
    FROM chats
    WHERE id = ?
);

selectBranchMessagesByChat:
SELECT *
FROM chat_branch_messages
WHERE chat_id = ?
ORDER BY branch_number ASC, id ASC;

insertMessage:
INSERT INTO chat_messages(
    chat_id,
    api,
    model,
    role,
    message,
    params_info,
    created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

upsertFeatureState:
INSERT OR REPLACE INTO chat_profiles(
    id,
    name,
    is_long_term_memory_enabled,
    is_system_prompt_enabled,
    system_prompt_text,
    is_summarization_enabled,
    summarize_after_tokens,
    is_sliding_window_enabled,
    sliding_window_size,
    is_sticky_facts_enabled,
    sticky_facts_window_size,
    sticky_facts_system_message,
    is_branching_enabled,
    show_raw_history
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectProfiles:
SELECT *
FROM chat_profiles
ORDER BY id ASC;

insertProfile:
INSERT INTO chat_profiles(
    name,
    is_long_term_memory_enabled,
    is_system_prompt_enabled,
    system_prompt_text,
    is_summarization_enabled,
    summarize_after_tokens,
    is_sliding_window_enabled,
    sliding_window_size,
    is_sticky_facts_enabled,
    sticky_facts_window_size,
    sticky_facts_system_message,
    is_branching_enabled,
    show_raw_history
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateProfile:
UPDATE chat_profiles
SET
    name = ?,
    is_long_term_memory_enabled = ?,
    is_system_prompt_enabled = ?,
    system_prompt_text = ?,
    is_summarization_enabled = ?,
    summarize_after_tokens = ?,
    is_sliding_window_enabled = ?,
    sliding_window_size = ?,
    is_sticky_facts_enabled = ?,
    sticky_facts_window_size = ?,
    sticky_facts_system_message = ?,
    is_branching_enabled = ?,
    show_raw_history = ?
WHERE id = ?;

deleteProfileById:
DELETE FROM chat_profiles
WHERE id = ?;

updateChatSelectedProfile:
UPDATE chats
SET selected_profile_id = ?
WHERE id = ?;

insertBranchMessage:
INSERT INTO chat_branch_messages(
    chat_id,
    branch_number,
    role,
    message,
    params_info,
    stream,
    epoch,
    created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

deleteMessagesByChat:
DELETE FROM chat_messages
WHERE chat_id = ?;

deleteFeatureStateByChat:
UPDATE chats
SET selected_profile_id = NULL
WHERE id = ?;

deleteBranchMessagesByChat:
DELETE FROM chat_branch_messages
WHERE chat_id = ?;

deleteBranchMessagesByChatAndBranch:
DELETE FROM chat_branch_messages
WHERE chat_id = ? AND branch_number = ?;

deleteBranchMessagesByChatExceptFirst:
DELETE FROM chat_branch_messages
WHERE chat_id = ? AND branch_number != 1;

deleteChatById:
DELETE FROM chats
WHERE id = ?;

deleteAllMessages:
DELETE FROM chat_messages;

deleteAllFeatureState:
DELETE FROM chat_profiles;

deleteAllBranchMessages:
DELETE FROM chat_branch_messages;

deleteAllChats:
DELETE FROM chats;

selectMemoryEntriesByProfile:
SELECT *
FROM memory_entries
WHERE profile_id = ?
ORDER BY id ASC;

insertMemoryEntry:
INSERT INTO memory_entries(profile_id, entry_key, entry_value, created_at, updated_at)
VALUES (?, ?, ?, ?, ?);

updateMemoryEntry:
UPDATE memory_entries SET entry_value = ?, updated_at = ? WHERE id = ?;

deleteMemoryEntry:
DELETE FROM memory_entries WHERE id = ?;

deleteAllMemoryEntriesByProfile:
DELETE FROM memory_entries
WHERE profile_id = ?;

CREATE TABLE app_settings (
    setting_key TEXT NOT NULL PRIMARY KEY,
    setting_value TEXT NOT NULL
);

selectAppSettingByKey:
SELECT *
FROM app_settings
WHERE setting_key = ?;

upsertAppSetting:
INSERT OR REPLACE INTO app_settings(setting_key, setting_value)
VALUES (?, ?);

deleteAppSettingByKey:
DELETE FROM app_settings
WHERE setting_key = ?;

deleteAllAppSettings:
DELETE FROM app_settings;

CREATE TABLE invariant_entries (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    entry_key TEXT NOT NULL,
    entry_value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

selectAllInvariantEntries:
SELECT * FROM invariant_entries ORDER BY id ASC;

insertInvariantEntry:
INSERT INTO invariant_entries(entry_key, entry_value, created_at, updated_at)
VALUES (?, ?, ?, ?);

updateInvariantEntry:
UPDATE invariant_entries SET entry_value = ?, updated_at = ? WHERE id = ?;

deleteInvariantEntry:
DELETE FROM invariant_entries WHERE id = ?;

deleteAllInvariantEntries:
DELETE FROM invariant_entries;

CREATE TABLE multi_agent_subagents (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    agent_key TEXT NOT NULL UNIQUE,
    title TEXT NOT NULL,
    description TEXT NOT NULL,
    is_enabled INTEGER NOT NULL,
    system_prompt TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

selectAllMultiAgentSubagents:
SELECT *
FROM multi_agent_subagents
ORDER BY id ASC;

selectMultiAgentSubagentByKey:
SELECT *
FROM multi_agent_subagents
WHERE agent_key = ?;

insertMultiAgentSubagent:
INSERT INTO multi_agent_subagents(
    agent_key,
    title,
    description,
    is_enabled,
    system_prompt,
    created_at,
    updated_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

updateMultiAgentSubagentEnabledByKey:
UPDATE multi_agent_subagents
SET
    is_enabled = ?,
    updated_at = ?
WHERE agent_key = ?;

CREATE TABLE multi_agent_runs (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    user_request TEXT NOT NULL,
    status TEXT NOT NULL,
    resolution_type TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

insertMultiAgentRun:
INSERT INTO multi_agent_runs(
    chat_id,
    user_request,
    status,
    resolution_type,
    created_at,
    updated_at
)
VALUES (?, ?, ?, ?, ?, ?);

selectLastInsertedMultiAgentRunId:
SELECT last_insert_rowid();

updateMultiAgentRunStatus:
UPDATE multi_agent_runs
SET
    status = ?,
    resolution_type = ?,
    updated_at = ?
WHERE id = ?;

selectMultiAgentRunsByChat:
SELECT *
FROM multi_agent_runs
WHERE chat_id = ?
ORDER BY id ASC;

deleteMultiAgentRunsByChat:
DELETE FROM multi_agent_runs
WHERE chat_id = ?;

CREATE TABLE multi_agent_steps (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    run_id INTEGER NOT NULL REFERENCES multi_agent_runs(id) ON DELETE CASCADE,
    step_index INTEGER NOT NULL,
    title TEXT NOT NULL,
    assignee_agent_key TEXT NOT NULL,
    status TEXT NOT NULL,
    input_payload TEXT NOT NULL,
    output_payload TEXT NOT NULL,
    validation_note TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

insertMultiAgentStep:
INSERT INTO multi_agent_steps(
    run_id,
    step_index,
    title,
    assignee_agent_key,
    status,
    input_payload,
    output_payload,
    validation_note,
    created_at,
    updated_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateMultiAgentStepById:
UPDATE multi_agent_steps
SET
    status = ?,
    output_payload = ?,
    validation_note = ?,
    updated_at = ?
WHERE id = ?;

selectMultiAgentStepsByRun:
SELECT *
FROM multi_agent_steps
WHERE run_id = ?
ORDER BY step_index ASC, id ASC;

deleteAllMultiAgentSteps:
DELETE FROM multi_agent_steps;

CREATE TABLE multi_agent_events (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    run_id INTEGER REFERENCES multi_agent_runs(id) ON DELETE CASCADE,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    channel TEXT NOT NULL,
    actor_type TEXT NOT NULL,
    actor_key TEXT NOT NULL,
    role TEXT NOT NULL,
    message TEXT NOT NULL,
    metadata_json TEXT NOT NULL,
    created_at INTEGER NOT NULL
);

insertMultiAgentEvent:
INSERT INTO multi_agent_events(
    run_id,
    chat_id,
    channel,
    actor_type,
    actor_key,
    role,
    message,
    metadata_json,
    created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

selectMultiAgentEventsByChat:
SELECT *
FROM multi_agent_events
WHERE chat_id = ?
ORDER BY id ASC;

deleteMultiAgentEventsByChat:
DELETE FROM multi_agent_events
WHERE chat_id = ?;

deleteAllMultiAgentEvents:
DELETE FROM multi_agent_events;

deleteAllMultiAgentRuns:
DELETE FROM multi_agent_runs;
