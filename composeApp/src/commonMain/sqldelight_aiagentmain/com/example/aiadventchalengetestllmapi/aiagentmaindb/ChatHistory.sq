CREATE TABLE chats (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    selected_profile_id INTEGER REFERENCES chat_profiles(id) ON DELETE SET NULL
);

CREATE TABLE chat_messages (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    api TEXT NOT NULL,
    model TEXT NOT NULL,
    role TEXT NOT NULL,
    message TEXT NOT NULL,
    params_info TEXT NOT NULL,
    created_at INTEGER NOT NULL
);

CREATE TABLE chat_profiles (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    is_long_term_memory_enabled INTEGER NOT NULL,
    is_system_prompt_enabled INTEGER NOT NULL,
    system_prompt_text TEXT NOT NULL,
    is_summarization_enabled INTEGER NOT NULL,
    summarize_after_tokens TEXT NOT NULL,
    is_sliding_window_enabled INTEGER NOT NULL,
    sliding_window_size TEXT NOT NULL,
    is_sticky_facts_enabled INTEGER NOT NULL,
    sticky_facts_window_size TEXT NOT NULL,
    sticky_facts_system_message TEXT NOT NULL,
    is_branching_enabled INTEGER NOT NULL,
    show_raw_history INTEGER NOT NULL
);

CREATE TABLE chat_branch_messages (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    chat_id INTEGER NOT NULL REFERENCES chats(id) ON DELETE CASCADE,
    branch_number INTEGER NOT NULL,
    role TEXT NOT NULL,
    message TEXT NOT NULL,
    params_info TEXT NOT NULL,
    stream TEXT NOT NULL,
    epoch INTEGER NOT NULL,
    created_at INTEGER NOT NULL
);

CREATE TABLE memory_entries (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    profile_id INTEGER NOT NULL REFERENCES chat_profiles(id) ON DELETE CASCADE,
    entry_key TEXT NOT NULL,
    entry_value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

selectChats:
SELECT *
FROM chats
ORDER BY id ASC;

insertChat:
INSERT INTO chats(
    title,
    created_at,
    selected_profile_id
)
VALUES (?, ?, ?);

selectChatById:
SELECT *
FROM chats
WHERE id = ?;

selectLastInsertedChatId:
SELECT last_insert_rowid();

selectMessagesByChat:
SELECT *
FROM chat_messages
WHERE chat_id = ?
ORDER BY id ASC;

selectFeatureStateByChat:
SELECT *
FROM chat_profiles
WHERE id = (
    SELECT selected_profile_id
    FROM chats
    WHERE id = ?
);

selectBranchMessagesByChat:
SELECT *
FROM chat_branch_messages
WHERE chat_id = ?
ORDER BY branch_number ASC, id ASC;

insertMessage:
INSERT INTO chat_messages(
    chat_id,
    api,
    model,
    role,
    message,
    params_info,
    created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

upsertFeatureState:
INSERT OR REPLACE INTO chat_profiles(
    id,
    name,
    is_long_term_memory_enabled,
    is_system_prompt_enabled,
    system_prompt_text,
    is_summarization_enabled,
    summarize_after_tokens,
    is_sliding_window_enabled,
    sliding_window_size,
    is_sticky_facts_enabled,
    sticky_facts_window_size,
    sticky_facts_system_message,
    is_branching_enabled,
    show_raw_history
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectProfiles:
SELECT *
FROM chat_profiles
ORDER BY id ASC;

insertProfile:
INSERT INTO chat_profiles(
    name,
    is_long_term_memory_enabled,
    is_system_prompt_enabled,
    system_prompt_text,
    is_summarization_enabled,
    summarize_after_tokens,
    is_sliding_window_enabled,
    sliding_window_size,
    is_sticky_facts_enabled,
    sticky_facts_window_size,
    sticky_facts_system_message,
    is_branching_enabled,
    show_raw_history
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateProfile:
UPDATE chat_profiles
SET
    name = ?,
    is_long_term_memory_enabled = ?,
    is_system_prompt_enabled = ?,
    system_prompt_text = ?,
    is_summarization_enabled = ?,
    summarize_after_tokens = ?,
    is_sliding_window_enabled = ?,
    sliding_window_size = ?,
    is_sticky_facts_enabled = ?,
    sticky_facts_window_size = ?,
    sticky_facts_system_message = ?,
    is_branching_enabled = ?,
    show_raw_history = ?
WHERE id = ?;

deleteProfileById:
DELETE FROM chat_profiles
WHERE id = ?;

updateChatSelectedProfile:
UPDATE chats
SET selected_profile_id = ?
WHERE id = ?;

insertBranchMessage:
INSERT INTO chat_branch_messages(
    chat_id,
    branch_number,
    role,
    message,
    params_info,
    stream,
    epoch,
    created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

deleteMessagesByChat:
DELETE FROM chat_messages
WHERE chat_id = ?;

deleteFeatureStateByChat:
UPDATE chats
SET selected_profile_id = NULL
WHERE id = ?;

deleteBranchMessagesByChat:
DELETE FROM chat_branch_messages
WHERE chat_id = ?;

deleteBranchMessagesByChatAndBranch:
DELETE FROM chat_branch_messages
WHERE chat_id = ? AND branch_number = ?;

deleteBranchMessagesByChatExceptFirst:
DELETE FROM chat_branch_messages
WHERE chat_id = ? AND branch_number != 1;

deleteChatById:
DELETE FROM chats
WHERE id = ?;

deleteAllMessages:
DELETE FROM chat_messages;

deleteAllFeatureState:
DELETE FROM chat_profiles;

deleteAllBranchMessages:
DELETE FROM chat_branch_messages;

deleteAllChats:
DELETE FROM chats;

selectMemoryEntriesByProfile:
SELECT *
FROM memory_entries
WHERE profile_id = ?
ORDER BY id ASC;

insertMemoryEntry:
INSERT INTO memory_entries(profile_id, entry_key, entry_value, created_at, updated_at)
VALUES (?, ?, ?, ?, ?);

updateMemoryEntry:
UPDATE memory_entries SET entry_value = ?, updated_at = ? WHERE id = ?;

deleteMemoryEntry:
DELETE FROM memory_entries WHERE id = ?;

deleteAllMemoryEntriesByProfile:
DELETE FROM memory_entries
WHERE profile_id = ?;

CREATE TABLE app_settings (
    setting_key TEXT NOT NULL PRIMARY KEY,
    setting_value TEXT NOT NULL
);

selectAppSettingByKey:
SELECT *
FROM app_settings
WHERE setting_key = ?;

upsertAppSetting:
INSERT OR REPLACE INTO app_settings(setting_key, setting_value)
VALUES (?, ?);

deleteAppSettingByKey:
DELETE FROM app_settings
WHERE setting_key = ?;

deleteAllAppSettings:
DELETE FROM app_settings;

CREATE TABLE invariant_entries (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    entry_key TEXT NOT NULL,
    entry_value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL
);

selectAllInvariantEntries:
SELECT * FROM invariant_entries ORDER BY id ASC;

insertInvariantEntry:
INSERT INTO invariant_entries(entry_key, entry_value, created_at, updated_at)
VALUES (?, ?, ?, ?);

updateInvariantEntry:
UPDATE invariant_entries SET entry_value = ?, updated_at = ? WHERE id = ?;

deleteInvariantEntry:
DELETE FROM invariant_entries WHERE id = ?;

deleteAllInvariantEntries:
DELETE FROM invariant_entries;
